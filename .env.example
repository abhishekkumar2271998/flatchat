# StenoAI secrets and API configuration template.
# Copy this file to .env and fill in real values. The .env file is gitignored.

# PostHog telemetry
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Google Calendar OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Outlook Calendar OAuth2 (PKCE public client — no client secret)
OUTLOOK_CLIENT_ID=
